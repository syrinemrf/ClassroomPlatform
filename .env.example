# ITBS Courses - Environment variables example
# Copy to .env locally and set real values. Do NOT commit .env.

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development

# SQL Server connection string
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=ITBS_CoursesDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True

# Admin seed account
AdminSeed__Email=admin@itbs-courses.local
AdminSeed__Password=ChangeMe_Strong#Password1
