@model ITBS_Classroom.Models.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Mot de passe"; }

<div class="uc-page-header">
    <h1><i class="fa fa-lock me-2 text-blue"></i>Changer le mot de passe</h1>
</div>

<div style="max-width:420px">
    <div class="uc-card">
        <div class="uc-card-body">
            <div asp-validation-summary="All" class="uc-alert uc-alert-error mb-2"></div>
            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div class="uc-form-group">
                    <label asp-for="CurrentPassword" class="uc-label">Mot de passe actuel</label>
                    <input asp-for="CurrentPassword" type="password" class="uc-input" autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="text-red" style="font-size:.8rem"></span>
                </div>
                <div class="uc-form-group">
                    <label asp-for="NewPassword" class="uc-label">Nouveau mot de passe</label>
                    <input asp-for="NewPassword" type="password" class="uc-input" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-red" style="font-size:.8rem"></span>
                </div>
                <div class="uc-form-group">
                    <label asp-for="ConfirmNewPassword" class="uc-label">Confirmer le mot de passe</label>
                    <input asp-for="ConfirmNewPassword" type="password" class="uc-input" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-red" style="font-size:.8rem"></span>
                </div>
                <button class="uc-btn uc-btn-primary" type="submit">
                    <i class="fa fa-key"></i> Mettre a jour
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
