@model ITBS_Classroom.Models.Account.ChangePasswordViewModel
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Changer le mot de passe" : "Change password";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card app-card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">@(isFr ? "Changer le mot de passe" : "Change password")</h2>
                @if (TempData["StatusMessage"] is string message)
                {
                    <div class="alert alert-success">@message</div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small"></div>
                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">@(isFr ? "Mot de passe actuel" : "Current password")</label>
                        <input asp-for="CurrentPassword" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">@(isFr ? "Nouveau mot de passe" : "New password")</label>
                        <input asp-for="NewPassword" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label">@(isFr ? "Confirmer le nouveau mot de passe" : "Confirm new password")</label>
                        <input asp-for="ConfirmNewPassword" class="form-control" />
                    </div>
                    <button class="btn btn-primary w-100" type="submit">@(isFr ? "Mettre Á jour" : "Update")</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
