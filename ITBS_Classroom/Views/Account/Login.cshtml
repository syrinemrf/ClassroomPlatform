@model ITBS_Classroom.Models.Account.LoginViewModel
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Connexion" : "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card app-card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">@(isFr ? "Connexion" : "Login")</h2>
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">@(isFr ? "Mot de passe" : "Password")</label>
                        <input asp-for="Password" class="form-control" />
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">@(isFr ? "Se souvenir de moi" : "Remember me")</label>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">@(isFr ? "Se connecter" : "Sign in")</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
