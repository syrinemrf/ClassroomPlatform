@model ITBS_Classroom.Models.ViewModels.ManageAccountViewModel
@{ ViewData["Title"] = "Mon profil"; }

<div class="uc-page-header">
    <h1><i class="fa fa-user-circle me-2 text-blue"></i>Mon profil</h1>
</div>

<div style="max-width:540px">
    <div class="uc-card">
        <div class="uc-card-body">
            <div asp-validation-summary="All" class="uc-alert uc-alert-error mb-2"></div>
            <form asp-action="Profile" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                    <div class="uc-form-group">
                        <label asp-for="FirstName" class="uc-label">Prenom</label>
                        <input asp-for="FirstName" class="uc-input" />
                        <span asp-validation-for="FirstName" class="text-red" style="font-size:.8rem"></span>
                    </div>
                    <div class="uc-form-group">
                        <label asp-for="LastName" class="uc-label">Nom</label>
                        <input asp-for="LastName" class="uc-input" />
                        <span asp-validation-for="LastName" class="text-red" style="font-size:.8rem"></span>
                    </div>
                </div>
                <div class="uc-form-group">
                    <label asp-for="Email" class="uc-label">Email</label>
                    <input asp-for="Email" class="uc-input" disabled style="opacity:.7" />
                </div>
                <div class="uc-form-group">
                    <label asp-for="PhoneNumber" class="uc-label">Telephone</label>
                    <input asp-for="PhoneNumber" class="uc-input" type="tel" />
                </div>
                <div class="uc-form-group">
                    <label asp-for="ProfileImage" class="uc-label">Photo de profil</label>
                    <input asp-for="ProfileImage" type="file" class="uc-input" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="ProfileImage" class="text-red" style="font-size:.8rem"></span>
                </div>
                <button class="uc-btn uc-btn-primary" type="submit">
                    <i class="fa fa-save"></i> Enregistrer
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
