@model ITBS_Classroom.Models.Admin.CreatePlatformUserViewModel
@using ITBS_Classroom.Domain.Enums
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Gestion utilisateurs" : "User management";
    var users = ViewBag.Users as IEnumerable<ITBS_Classroom.Domain.Entities.ApplicationUser> ?? Enumerable.Empty<ITBS_Classroom.Domain.Entities.ApplicationUser>();
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card app-card border-0 shadow-sm">
            <div class="card-body">
                <h5>@(isFr ? "Créer un utilisateur" : "Create user")</h5>
                <form asp-action="CreateUser" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small"></div>
                    <input asp-for="FirstName" class="form-control mb-2" placeholder="@(isFr ? "Prénom" : "First name")" />
                    <input asp-for="LastName" class="form-control mb-2" placeholder="@(isFr ? "Nom" : "Last name")" />
                    <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
                    <input asp-for="Password" class="form-control mb-2" placeholder="@(isFr ? "Mot de passe" : "Password")" />
                    <select asp-for="Role" class="form-select mb-3">
                        <option value="@ApplicationRoles.Teacher">Teacher</option>
                        <option value="@ApplicationRoles.Student">Student</option>
                    </select>
                    <button class="btn btn-primary w-100" type="submit">@(isFr ? "Créer" : "Create")</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card app-card border-0 shadow-sm">
            <div class="card-body">
                <h5>@(isFr ? "Liste des utilisateurs" : "Users list")</h5>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead><tr><th>@(isFr ? "Nom" : "Name")</th><th>Email</th></tr></thead>
                        <tbody>
                        @foreach (var user in users)
                        {
                            <tr><td>@user.FirstName @user.LastName</td><td>@user.Email</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
