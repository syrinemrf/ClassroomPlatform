@model IEnumerable<ITBS_Classroom.Models.Assignment>
@using ITBS_Classroom.Models
@{
    ViewData["Title"] = "Devoirs";
    var submissionStatuses = ViewBag.SubmissionStatuses as Dictionary<Guid, SubmissionStatus> ?? new();
    var isStudent = User.IsInRole(ApplicationRoles.Student);
    var isTeacher = User.IsInRole(ApplicationRoles.Teacher) || User.IsInRole(ApplicationRoles.Admin);
}

<div class="uc-page-header">
    <h1><i class="fa fa-tasks me-2 text-blue"></i>Devoirs</h1>
    <p>@Model.Count() devoir(s) au total</p>
</div>

@if (!Model.Any())
{
    <div class="uc-empty uc-card"><i class="fa fa-tasks"></i><p>Aucun devoir disponible.</p></div>
}
else
{
    @foreach (var a in Model)
    {
        var days = (a.DeadlineUtc - DateTime.UtcNow).TotalDays;
        var cls = days < 0 ? "uc-deadline-past" : days < 1 ? "uc-deadline-urgent" : days < 3 ? "uc-deadline-soon" : "uc-deadline-ok";
        <div class="uc-assignment-item">
            <div class="uc-assignment-icon"><i class="fa fa-clipboard-list"></i></div>
            <div style="flex:1">
                <div style="font-weight:600">@a.Title</div>
                <div class="text-soft" style="font-size:.82rem">
                    <i class="fa fa-book-open me-1"></i>@a.Course.Title
                    &nbsp;·&nbsp;<i class="fa fa-user me-1"></i>@a.Course.Teacher.FullName
                </div>
                <div class="text-soft" style="font-size:.8rem;margin-top:2px">@a.Description.Substring(0, Math.Min(100, a.Description.Length))@(a.Description.Length > 100 ? "…" : "")</div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px">
                <span class="uc-deadline @cls">@a.DeadlineUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                @if (isStudent)
                {
                    var status = submissionStatuses.GetValueOrDefault(a.Id);
                    if (status == SubmissionStatus.Submitted)
                    { <span style="font-size:.78rem;color:#34a853;font-weight:600"><i class="fa fa-check"></i> Rendu</span> }
                    else if (days > 0)
                    {
                        <a class="uc-btn uc-btn-primary uc-btn-sm"
                           asp-controller="Assignments" asp-action="Submit" asp-route-assignmentId="@a.Id">
                            <i class="fa fa-upload"></i> Rendre
                        </a>
                    }
                }
                @if (isTeacher)
                {
                    <a class="uc-btn uc-btn-outline uc-btn-sm"
                       asp-controller="Submissions" asp-action="ByAssignment" asp-route-assignmentId="@a.Id">
                        <i class="fa fa-eye"></i> Rendus
                    </a>
                }
            </div>
        </div>
    }
}
