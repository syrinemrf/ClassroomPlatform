@model IEnumerable<ITBS_Classroom.Domain.Entities.CalendarEvent>
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Calendrier" : "Calendar";
    var groups = ViewBag.Groups as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<h2 class="mb-3">@(isFr ? "Calendrier" : "Calendar")</h2>

@if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
{
    <div class="card app-card border-0 shadow-sm mb-4"><div class="card-body">
        <h5>@(isFr ? "Nouvel ÈvÈnement" : "New event")</h5>
        <form asp-action="Create" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <div class="col-md-4"><select name="GroupId" asp-items="groups" class="form-select" required></select></div>
            <div class="col-md-4"><input name="Title" class="form-control" placeholder="@(isFr ? "Titre" : "Title")" required /></div>
            <div class="col-md-4"><input name="Description" class="form-control" placeholder="@(isFr ? "Description" : "Description")" required /></div>
            <div class="col-md-4"><input name="StartUtc" type="datetime-local" class="form-control" required /></div>
            <div class="col-md-4"><input name="EndUtc" type="datetime-local" class="form-control" required /></div>
            <div class="col-md-2 form-check mt-2 ms-2"><input class="form-check-input" type="checkbox" name="IsExam" value="true" /><label class="form-check-label">@(isFr ? "Examen" : "Exam")</label></div>
            <div class="col-md-2"><button class="btn btn-primary w-100" type="submit">@(isFr ? "CrÈer" : "Create")</button></div>
        </form>
    </div></div>
}

<div class="table-responsive">
<table class="table align-middle">
<thead><tr><th>Titre</th><th>Groupe</th><th>DÈbut</th><th>Fin</th><th>Type</th></tr></thead>
<tbody>
@foreach (var e in Model)
{
    <tr>
        <td>@e.Title</td>
        <td>@e.Group.Name</td>
        <td>@e.StartUtc</td>
        <td>@e.EndUtc</td>
        <td>@(e.IsExam ? "Exam" : "Session")</td>
    </tr>
}
</tbody>
</table>
</div>
