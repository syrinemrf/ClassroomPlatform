@model IEnumerable<ITBS_Classroom.Domain.Entities.Course>
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Cours" : "Courses";
    var groups = ViewBag.Groups as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<h2 class="mb-3">@(isFr ? "Cours" : "Courses")</h2>

@if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
{
    <div class="card app-card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5>@(isFr ? "Nouveau cours" : "New course")</h5>
            <form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-4"><input name="Title" class="form-control" placeholder="@(isFr ? "Titre" : "Title")" required /></div>
                <div class="col-md-4"><input name="Description" class="form-control" placeholder="@(isFr ? "Description" : "Description")" required /></div>
                <div class="col-md-4"><select name="GroupId" asp-items="groups" class="form-select" required></select></div>
                <div class="col-md-8"><input name="File" type="file" class="form-control" required /></div>
                <div class="col-md-4"><button class="btn btn-primary w-100" type="submit">@(isFr ? "Publier" : "Publish")</button></div>
            </form>
        </div>
    </div>
}

<div class="row g-3">
    @foreach (var course in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card app-card h-100 border-0 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5>@course.Title</h5>
                    <p class="text-muted small">@course.Description</p>
                    <p class="small mb-1">@(isFr ? "Groupe" : "Group"): @course.Group.Name</p>
                    <p class="small">@(isFr ? "Enseignant" : "Teacher"): @course.Teacher.FirstName @course.Teacher.LastName</p>
                    <div class="mt-auto d-flex gap-2">
                        <a class="btn btn-outline-primary btn-sm" asp-action="Download" asp-route-id="@course.Id">@(isFr ? "Télécharger" : "Download")</a>
                        @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                        {
                            <form asp-action="Delete" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@course.Id" />
                                <button class="btn btn-outline-danger btn-sm" type="submit">@(isFr ? "Supprimer" : "Delete")</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
