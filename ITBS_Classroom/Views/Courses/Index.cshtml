@model IEnumerable<ITBS_Classroom.Models.Course>
@using ITBS_Classroom.Models
@{ ViewData["Title"] = "Mes cours"; }

<div class="uc-page-header">
    <h1><i class="fa fa-book-open me-2 text-blue"></i>Mes cours</h1>
    <p>@Model.Count() cours disponibles</p>
</div>

@if (!Model.Any())
{
    <div class="uc-empty uc-card">
        <i class="fa fa-book-open"></i>
        <p>Aucun cours disponible pour le moment.</p>
    </div>
}
else
{
    <div class="uc-courses-grid">
        @foreach (var course in Model)
        {
            <a class="uc-course-card" asp-controller="Courses" asp-action="Detail" asp-route-id="@course.Id"
               style="text-decoration:none;color:inherit">
                <div class="uc-course-header" style="background:@course.ColorTheme" data-initials="@course.Title[0]">
                    <h3 class="uc-course-title">@course.Title</h3>
                    @if (!string.IsNullOrEmpty(course.Section))
                    { <div class="uc-course-section">@course.Section</div> }
                    <div class="uc-course-teacher-bubble">@course.Teacher.Initials</div>
                </div>
                <div class="uc-course-body">
                    <div class="uc-course-teacher">@course.Teacher.FullName</div>
                    <div class="uc-course-meta">
                        <i class="fa fa-users me-1"></i>@course.Enrollments.Count etudiants
                    </div>
                    @if (!string.IsNullOrWhiteSpace(course.Description))
                    {
                        <div class="uc-course-meta" style="margin-top:4px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">
                            @course.Description
                        </div>
                    }
                </div>
                <div class="uc-course-footer">
                    <button class="uc-course-action" title="Supports de cours"><i class="fa fa-folder-open"></i></button>
                    <button class="uc-course-action" title="Devoirs"><i class="fa fa-clipboard-list"></i></button>
                    <button class="uc-course-action" title="Voir le cours"><i class="fa fa-arrow-right"></i></button>
                </div>
            </a>
        }
    </div>
}
