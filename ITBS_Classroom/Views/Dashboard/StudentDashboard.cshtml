@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Espace Ètudiant" : "Student area";
}
<div class="card app-card border-0 shadow-sm">
    <div class="card-body">
        <h3>@(isFr ? "Bienvenue Ètudiant" : "Welcome student")</h3>
        <p>@(isFr ? "Consultez vos cours, devoirs, notes et notifications." : "View your courses, assignments, grades, and notifications.")</p>
    </div>
</div>
