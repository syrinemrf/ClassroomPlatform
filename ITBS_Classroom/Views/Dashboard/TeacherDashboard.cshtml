@model ITBS_Classroom.Models.ViewModels.TeacherDashboardViewModel
@{ ViewData["Title"] = "Accueil Enseignant"; }

<div class="uc-page-header d-flex justify-between align-center flex-wrap gap-2">
    <div>
        <h1>Bonjour, @User.Identity?.Name?.Split('@')[0] ??</h1>
        <p>Voici un aperçu de vos cours et activités</p>
    </div>
</div>

<div class="uc-stats">
    <div class="uc-stat">
        <div class="uc-stat-num">@Model.Courses.Count</div>
        <div class="uc-stat-label">Cours</div>
    </div>
    <div class="uc-stat">
        <div class="uc-stat-num">@Model.TotalStudents</div>
        <div class="uc-stat-label">Etudiants</div>
    </div>
    <div class="uc-stat">
        <div class="uc-stat-num" style="color:#fa7b17">@Model.PendingSubmissions</div>
        <div class="uc-stat-label">A corriger</div>
    </div>
    <div class="uc-stat">
        <div class="uc-stat-num" style="color:#ea4335">@Model.UpcomingDeadlines</div>
        <div class="uc-stat-label">Deadlines proches</div>
    </div>
</div>

@if (Model.Courses.Count == 0)
{
    <div class="uc-empty uc-card">
        <i class="fa fa-book-open"></i>
        <p>Vous n'enseignez aucun cours pour le moment.</p>
        <p class="text-soft" style="font-size:.85rem">Contactez l'administrateur pour ętre assigné ŕ un cours.</p>
    </div>
}
else
{
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:16px">Vos cours</h2>
    <div class="uc-courses-grid">
        @foreach (var course in Model.Courses)
        {
            var studentCount = course.Enrollments.Count;
            var assignCount = course.Assignments.Count;
            <a class="uc-course-card" asp-controller="Courses" asp-action="Detail" asp-route-id="@course.Id"
               style="text-decoration:none;color:inherit">
                <div class="uc-course-header" style="background:@course.ColorTheme" data-initials="@course.Title[0]">
                    <h3 class="uc-course-title">@course.Title</h3>
                    @if (!string.IsNullOrEmpty(course.Section))
                    { <div class="uc-course-section">@course.Section</div> }
                    <div class="uc-course-teacher-bubble">@course.Teacher.Initials</div>
                </div>
                <div class="uc-course-body">
                    <div class="uc-course-teacher">@course.Teacher.FullName</div>
                    <div class="uc-course-meta">
                        <i class="fa fa-users me-1"></i>@studentCount etudiants
                        &nbsp;·&nbsp;<i class="fa fa-tasks me-1"></i>@assignCount devoirs
                    </div>
                </div>
                <div class="uc-course-footer">
                    <button class="uc-course-action" title="Supports"><i class="fa fa-folder-open"></i></button>
                    <button class="uc-course-action" title="Devoirs"><i class="fa fa-clipboard-list"></i></button>
                </div>
            </a>
        }
    </div>
}
