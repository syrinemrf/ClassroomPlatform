@using System.Globalization
@model ITBS_Classroom.Models.Dashboard.TeacherDashboardViewModel
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Espace enseignant" : "Teacher area";
}

<div class="card app-card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-1">@(isFr ? "Bienvenue enseignant" : "Welcome teacher")</h3>
            <p class="mb-0 text-muted">@(isFr ? "Voici vos groupes et vos cours." : "Here are your groups and courses.")</p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-primary">@(isFr ? "Groupes" : "Groups"): @Model.Groups.Count</span>
            <span class="badge bg-warning text-dark">@(isFr ? "Cours" : "Courses"): @Model.Courses.Count</span>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card app-card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="mb-3">@(isFr ? "Groupes enseignés" : "Taught groups")</h5>
                @if (Model.Groups.Count == 0)
                {
                    <p class="text-muted mb-0">@(isFr ? "Aucun groupe assigné." : "No assigned groups.")</p>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var group in Model.Groups)
                        {
                            <div class="list-group-item px-0 border-0 bg-transparent">
                                <div class="fw-semibold">@group.Name</div>
                                <div class="small text-muted">@group.Description</div>
                                <div class="small">@(isFr ? "Étudiants" : "Students"): @group.Students.Count</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card app-card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="mb-3">@(isFr ? "Cours de vos groupes" : "Courses in your groups")</h5>
                @if (Model.Courses.Count == 0)
                {
                    <p class="text-muted mb-0">@(isFr ? "Aucun cours pour le moment." : "No courses yet.")</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>@(isFr ? "Titre" : "Title")</th>
                                    <th>@(isFr ? "Groupe" : "Group")</th>
                                    <th>@(isFr ? "Date" : "Date")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Model.Courses)
                                {
                                    <tr>
                                        <td>@course.Title</td>
                                        <td>@course.Group.Name</td>
                                        <td>@course.CreatedAtUtc.ToLocalTime()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
