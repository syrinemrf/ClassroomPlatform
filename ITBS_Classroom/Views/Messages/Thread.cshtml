@model ITBS_Classroom.Models.MessageThread
@using ITBS_Classroom.Models.ViewModels
@{
    ViewData["Title"] = "Conversation";
    var userId = ViewBag.UserId as string;
    var sendModel = ViewBag.SendModel as SendMessageViewModel;
    var other = Model.Participants.FirstOrDefault(p => p.UserId != userId)?.User;
}

<div class="uc-page-header d-flex justify-between align-center">
    <div style="display:flex;align-items:center;gap:12px">
        <div class="uc-avatar" style="width:44px;height:44px;font-size:1.05rem">@(other?.Initials ?? "?")</div>
        <div>
            <h1 style="margin:0;font-size:1.2rem">@(other?.FullName ?? "Discussion")</h1>
            @if (Model.Course is not null)
            { <p style="margin:0">@Model.Course.Title</p> }
        </div>
    </div>
    <a class="uc-btn uc-btn-ghost" asp-controller="Messages" asp-action="Index">
        <i class="fa fa-arrow-left"></i> Retour
    </a>
</div>

<div class="uc-card" style="overflow:hidden">
    <div class="uc-chat-area" id="chatArea">
        @foreach (var msg in Model.Messages)
        {
            var mine = msg.SenderId == userId;
            <div class="uc-chat-row @(mine ? "mine" : "")">
                @if (!mine)
                {
                    <div class="uc-avatar" style="width:30px;height:30px;font-size:.7rem;flex-shrink:0;margin-right:8px">
                        @msg.Sender.Initials
                    </div>
                }
                <div>
                    @if (!mine)
                    { <div style="font-size:.75rem;color:#5f6368;margin-bottom:2px">@msg.Sender.FullName</div> }
                    <div class="uc-msg-bubble @(mine ? "mine" : "theirs")">@msg.Content</div>
                    <div style="font-size:.7rem;color:#9aa0a6;margin-top:2px;text-align:@(mine ? "right" : "left")">
                        @msg.SentAtUtc.ToLocalTime().ToString("HH:mm")
                    </div>
                </div>
            </div>
        }
    </div>
    <!-- Send form -->
    <div style="padding:12px 16px;border-top:1px solid #dadce0;display:flex;gap:10px">
        <form asp-controller="Messages" asp-action="Send" method="post" style="display:flex;gap:10px;flex:1">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ThreadId" value="@Model.Id" />
            <input name="Content" class="uc-input" placeholder="Votre message…" required maxlength="4000" style="flex:1" autocomplete="off" />
            <button class="uc-btn uc-btn-primary" type="submit">
                <i class="fa fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
var chatArea = document.getElementById('chatArea');
if (chatArea) chatArea.scrollTop = chatArea.scrollHeight;
</script>
}
