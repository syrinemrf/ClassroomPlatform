@model IEnumerable<ITBS_Classroom.Domain.Entities.Notification>
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Notifications" : "Notifications";
}

<h2>Notifications</h2>
@foreach (var n in Model)
{
    <div class="card app-card border-0 shadow-sm mb-2">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-semibold">@n.Message</div>
                <div class="small text-muted">@n.CreatedAtUtc</div>
            </div>
            @if (!n.IsRead)
            {
                <form asp-action="MarkAsRead" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@n.Id" />
                    <button class="btn btn-sm btn-outline-primary" type="submit">@(isFr ? "Marquer lu" : "Mark as read")</button>
                </form>
            }
        </div>
    </div>
}
