@model IEnumerable<ITBS_Classroom.Models.Notification>
@using ITBS_Classroom.Models
@{ ViewData["Title"] = "Notifications"; }

<div class="uc-page-header d-flex justify-between align-center">
    <div>
        <h1><i class="fa fa-bell me-2 text-blue"></i>Notifications</h1>
        <p>@Model.Count(n => !n.IsRead) non lue(s)</p>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button class="uc-btn uc-btn-outline uc-btn-sm" type="submit">
                <i class="fa fa-check-double"></i> Tout marquer comme lu
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="uc-empty uc-card"><i class="fa fa-bell-slash"></i><p>Aucune notification.</p></div>
}
else
{
    <div class="uc-card">
        @foreach (var n in Model)
        {
            var icon = n.Type switch {
                NotificationType.AssignmentCreated => "fa-tasks",
                NotificationType.GradePublished => "fa-star",
                NotificationType.CourseUploaded => "fa-file-upload",
                NotificationType.DeadlineReminder => "fa-clock",
                _ => "fa-info-circle"
            };
            var color = n.Type switch {
                NotificationType.AssignmentCreated => "#1a73e8",
                NotificationType.GradePublished => "#34a853",
                NotificationType.CourseUploaded => "#fa7b17",
                NotificationType.DeadlineReminder => "#ea4335",
                _ => "#5f6368"
            };
            <div class="uc-notif-item @(n.IsRead ? "" : "unread")">
                <div style="width:38px;height:38px;border-radius:50%;background:@(color + "20");color:@color;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                    <i class="fa @icon"></i>
                </div>
                <div style="flex:1">
                    <div style="font-size:.9rem;@(n.IsRead ? "" : "font-weight:600")">@n.Message</div>
                    <div class="text-soft" style="font-size:.78rem">@n.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                @if (!n.IsRead)
                {
                    <form asp-action="MarkRead" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@n.Id" />
                        <button class="uc-btn uc-btn-ghost uc-btn-sm" type="submit">
                            <i class="fa fa-check"></i>
                        </button>
                    </form>
                }
            </div>
        }
    </div>
}
