@using ITBS_Classroom.Models
@{
    var path = Context.Request.Path.Value?.ToLowerInvariant() ?? "";
    string Nav(string prefix) => path.StartsWith(prefix) ? "active" : "";
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var isAdmin = User.IsInRole(ApplicationRoles.Admin);
    var isTeacher = User.IsInRole(ApplicationRoles.Teacher);
    var isStudent = User.IsInRole(ApplicationRoles.Student);
    var userInitials = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UniClassroom</title>
    <link rel="icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (isAuth)
{
    <!-- TOP NAVBAR -->
    <header class="uc-topbar">
        <div class="uc-topbar-left">
            <button class="uc-sidebar-toggle" id="sidebarToggle" aria-label="Menu">
                <i class="fa fa-bars"></i>
            </button>
            <a class="uc-brand" asp-controller="Dashboard" asp-action="Index">
                <span class="uc-brand-icon"><i class="fa-solid fa-graduation-cap"></i></span>
                <span class="uc-brand-text">UniClassroom</span>
            </a>
        </div>
        <div class="uc-topbar-right">
            <a class="uc-topbar-btn" asp-controller="Notifications" asp-action="Index"
               title="Notifications" id="notifBell">
                <i class="fa fa-bell"></i>
                <span class="uc-badge" id="notifCount" style="display:none"></span>
            </a>
            @if (isTeacher || isStudent)
            {
                <a class="uc-topbar-btn" asp-controller="Messages" asp-action="Index" title="Messages">
                    <i class="fa fa-envelope"></i>
                </a>
            }
            <div class="uc-avatar-dropdown">
                <button class="uc-avatar" id="avatarBtn" aria-label="Account">
                    @userInitials
                </button>
                <div class="uc-dropdown" id="avatarDropdown">
                    <div class="uc-dropdown-header">
                        <div class="uc-avatar uc-avatar-lg">@userInitials</div>
                        <div>
                            <div class="fw-semibold">@User.Identity?.Name</div>
                            <div class="uc-role-badge">
                                @(isAdmin ? "Administrateur" : isTeacher ? "Enseignant" : "Etudiant")
                            </div>
                        </div>
                    </div>
                    @if (isTeacher || isStudent)
                    {
                        <a class="uc-dropdown-item" asp-controller="Account" asp-action="Profile">
                            <i class="fa fa-user-circle me-2"></i>Mon profil
                        </a>
                    }
                    <a class="uc-dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                        <i class="fa fa-lock me-2"></i>Mot de passe
                    </a>
                    <div class="uc-dropdown-divider"></div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button class="uc-dropdown-item uc-dropdown-danger" type="submit">
                            <i class="fa fa-sign-out-alt me-2"></i>Deconnexion
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </header>

    <!-- LAYOUT -->
    <div class="uc-shell">
        <!-- SIDEBAR -->
        <aside class="uc-sidebar" id="sidebar">
            <nav class="uc-nav">
                <a class="uc-nav-item @Nav("/dashboard")" asp-controller="Dashboard" asp-action="Index">
                    <i class="fa fa-home"></i><span>Accueil</span>
                </a>
                <a class="uc-nav-item @Nav("/courses")" asp-controller="Courses" asp-action="Index">
                    <i class="fa fa-book-open"></i><span>Mes cours</span>
                </a>
                <a class="uc-nav-item @Nav("/calendar")" asp-controller="Calendar" asp-action="Index">
                    <i class="fa fa-calendar-alt"></i><span>Calendrier</span>
                </a>
                @if (isStudent)
                {
                    <a class="uc-nav-item @Nav("/submissions/mygrades")" asp-controller="Submissions" asp-action="MyGrades">
                        <i class="fa fa-chart-bar"></i><span>Mes notes</span>
                    </a>
                }
                @if (isTeacher || isStudent)
                {
                    <a class="uc-nav-item @Nav("/messages")" asp-controller="Messages" asp-action="Index">
                        <i class="fa fa-comments"></i><span>Messages</span>
                    </a>
                }
                <a class="uc-nav-item @Nav("/notifications")" asp-controller="Notifications" asp-action="Index">
                    <i class="fa fa-bell"></i><span>Notifications</span>
                </a>

                @if (isAdmin)
                {
                    <div class="uc-nav-section">Administration</div>
                    <a class="uc-nav-item @Nav("/admin/users")" asp-controller="Admin" asp-action="Users">
                        <i class="fa fa-users-cog"></i><span>Utilisateurs</span>
                    </a>
                    <a class="uc-nav-item @Nav("/admin/courses")" asp-controller="Admin" asp-action="Courses">
                        <i class="fa fa-chalkboard-teacher"></i><span>Cours</span>
                    </a>
                }
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="uc-main">
            @if (TempData["Success"] is string ok)
            {
                <div class="uc-alert uc-alert-success">
                    <i class="fa fa-check-circle me-2"></i>@ok
                </div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="uc-alert uc-alert-error">
                    <i class="fa fa-exclamation-circle me-2"></i>@err
                </div>
            }
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
