@model IEnumerable<ITBS_Classroom.Domain.Entities.Submission>
@using System.Globalization
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = isFr ? "Soumissions" : "Submissions";
}

<h2>@(isFr ? "Soumissions" : "Submissions")</h2>
<div class="table-responsive app-card p-3 shadow-sm">
<table class="table align-middle">
    <thead><tr><th>Étudiant</th><th>Date</th><th>Status</th><th>Note</th><th>Action</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Student.FirstName @item.Student.LastName</td>
            <td>@item.SubmittedAtUtc</td>
            <td>@item.Status</td>
            <td>@(item.Grade?.Score)</td>
            <td>
                <form asp-action="Grade" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SubmissionId" value="@item.Id" />
                    <input type="number" name="Score" min="0" max="100" step="0.5" class="form-control form-control-sm" style="max-width:90px" required />
                    <input type="text" name="Feedback" class="form-control form-control-sm" placeholder="Feedback" />
                    <button class="btn btn-sm btn-dark" type="submit">Publier</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
